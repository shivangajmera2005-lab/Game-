# ─────────────────────────────────────────────────────────────
#  Empire Climb — Environment Variables
# ─────────────────────────────────────────────────────────────
#
#  Copy this file to .env and fill in your values.
#  The .env file should NOT be committed to git.
#
# ─────────────────────────────────────────────────────────────

# Port the Socket.IO server listens on (local dev)
PORT=5931

# ─────────────────────────────────────────────────────────────
#  After deploying to Railway, copy the public URL and paste it
#  into the <script> config block inside lobby.html:
#
#  window.SOCKET_SERVER_URL = 'https://your-app.up.railway.app';
# ─────────────────────────────────────────────────────────────
